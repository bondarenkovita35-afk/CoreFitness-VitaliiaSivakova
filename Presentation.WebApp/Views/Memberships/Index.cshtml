@{
    ViewData["Title"] = "Memberships";
}

<section class="cf-section">
    <div class="cf-container">
        <div class="cf-section-heading-center">
            <h1 class="cf-page-title-center">Our Membership Offers</h1>
        </div>

        <div class="cf-membership-grid">
            <article class="cf-plan-card">
                <div class="cf-plan-icon"></div>
                <h3>Standard Membership</h3>
                <p>Great for beginners who want access to our gym and training basics.</p>
                <ul class="cf-plan-list">
                    <li>Standard locker</li>
                    <li>Gym access</li>
                    <li>Basic group classes</li>
                </ul>
                <div class="cf-plan-bottom">
                    <div>
                        <strong>495.00</strong>
                        <span>/ month</span>
                    </div>
                    <a class="cf-btn-primary" href="#">Join Now</a>
                </div>
            </article>

            <article class="cf-plan-card">
                <div class="cf-plan-icon"></div>
                <h3>Premium Membership</h3>
                <p>For members who want more classes, more support and better access.</p>
                <ul class="cf-plan-list">
                    <li>Priority support</li>
                    <li>All group classes</li>
                    <li>Private access zones</li>
                </ul>
                <div class="cf-plan-bottom">
                    <div>
                        <strong>595.00</strong>
                        <span>/ month</span>
                    </div>
                    <a class="cf-btn-primary" href="#">Join Now</a>
                </div>
            </article>

            <aside class="cf-membership-side-card">
                <div class="cf-membership-side-content">
                    <h3>Get Your Membership</h3>
                    <p>Our memberships give you access to all equipment, programs and support.</p>
                    <p class="cf-membership-phone">Call Us At: +(46) 8 410 821 00</p>
                    <a class="cf-btn-primary" href="#">Call Us Today</a>
                </div>
                <img src="~/images/membership-side.jpg" alt="Membership" class="cf-membership-side-image" />
            </aside>
        </div>

        <div class="cf-benefits-row">
            <span>Get 30-day free trial</span>
            <span>No hidden fees</span>
            <span>You can cancel anytime</span>
        </div>
    </div>
</section>

<section class="cf-section">
    <div class="cf-container cf-two-col">
        <div>
            <img src="~/images/faq-man.jpg" alt="FAQ training" class="cf-large-photo" />
        </div>

        <div class="cf-section-content">
            <span class="cf-section-label">Frequently Asked Questions</span>
            <h2 class="cf-section-title">Common questions about gym and training</h2>

            <div class="cf-faq-list">
                <div class="cf-faq-item cf-faq-item-open">
                    <h4>Q1. Do I need prior gym experience to join CoreFitness?</h4>
                    <p>No. Our programs are suitable for both beginners and experienced members.</p>
                </div>
                <div class="cf-faq-item"><h4>Q2. What facilities are included with the membership?</h4></div>
                <div class="cf-faq-item"><h4>Q3. Can I try the gym before taking a membership?</h4></div>
                <div class="cf-faq-item"><h4>Q4. Are there group workout programs available?</h4></div>
                <div class="cf-faq-item"><h4>Q5. Is nutrition guidance included in the plans?</h4></div>
            </div>
        </div>
    </div>
</section>