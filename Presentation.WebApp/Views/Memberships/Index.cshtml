@{
    ViewData["Title"] = "Memberships";
}

<section class="cf-page-section">
    <div class="cf-container">
        <div class="cf-section-heading">
            <h1>Our Membership Offers</h1>
        </div>

        <div class="cf-membership-grid">
            <div class="cf-plan-card">
                <div class="cf-plan-icon"></div>
                <h3>Standard Membership</h3>
                <p>Perfect for members who want flexible access and strong value.</p>

                <ul class="cf-plan-list">
                    <li>Standard locker</li>
                    <li>Access to gym facilities</li>
                    <li>Supportive environment</li>
                </ul>

                <div class="cf-plan-bottom">
                    <div>
                        <strong>495.00</strong>
                        <span> / monthly</span>
                    </div>
                    <a class="cf-btn-primary">Join Now</a>
                </div>
            </div>

            <div class="cf-plan-card">
                <div class="cf-plan-icon"></div>
                <h3>Premium Membership</h3>
                <p>For members who want more classes, premium support, and extra comfort.</p>

                <ul class="cf-plan-list">
                    <li>Priority support</li>
                    <li>More classes</li>
                    <li>Premium locker access</li>
                </ul>

                <div class="cf-plan-bottom">
                    <div>
                        <strong>595.00</strong>
                        <span> / monthly</span>
                    </div>
                    <a class="cf-btn-primary">Join Now</a>
                </div>
            </div>

            <div class="cf-membership-side-card">
                <div class="cf-membership-side-content">
                    <h3>Get Your Membership</h3>
                    <p>Start your training with us and achieve better results with expert support.</p>
                    <div class="cf-membership-phone">Call Us: +46 8 410 922 00</div>
                    <a class="cf-btn-primary">Call Us Today</a>
                </div>

                <img src="~/images/membership-image.png" alt="Membership image" class="cf-membership-side-image" />
            </div>
        </div>

        <div class="cf-benefits-row">
            <span>Get 30-day free trial</span>
            <span>No hidden fees</span>
            <span>You can cancel anytime</span>
        </div>
    </div>
</section>

<section class="cf-section">
    <div class="cf-container cf-two-col">
        <div>
            <img src="~/images/faq-image.png" alt="FAQ image" class="cf-large-photo" />
        </div>

        <div>
            <span class="cf-section-label">Frequently Asked Questions</span>

            <h2 class="cf-section-title">
                Common questions about gym and training
            </h2>

            <div class="cf-faq-list">
                <div class="cf-faq-item cf-faq-item-open">
                    <h4>Do I need prior gym experience to join CoreFitness?</h4>
                    <p>No. Our programs are designed for both beginners and experienced members.</p>
                </div>
                <div class="cf-faq-item"><h4>What facilities are included with the membership?</h4></div>
                <div class="cf-faq-item"><h4>Can I try the gym before taking a membership?</h4></div>
                <div class="cf-faq-item"><h4>Are there group workout programs available?</h4></div>
                <div class="cf-faq-item"><h4>Is nutrition guidance included in the plans?</h4></div>
            </div>
        </div>
    </div>
</section>

