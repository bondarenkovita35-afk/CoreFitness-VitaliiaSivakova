@{
    ViewData["Title"] = "Home";
}

<section class="cf-home-hero">
    <div class="cf-container cf-home-hero-inner">
        <div>
            <span class="cf-section-label">Strong body. Strong mind.</span>

            <h1 class="cf-home-title">
                Build Strength<br />
                Boost Confidence Today!
            </h1>

            <p class="cf-home-text">
                Begin your fitness journey with expert trainers, modern equipment,
                and a motivating environment built for real progress.
            </p>

            <ul class="cf-feature-list">
                <li>Professional trainers</li>
                <li>Flexible membership plans</li>
                <li>Modern equipment</li>
                <li>Personal support</li>
            </ul>

            <a asp-controller="Memberships" asp-action="Index" class="cf-btn-primary">Get Started</a>
        </div>

        <div class="cf-home-hero-image-wrap">
            <img src="~/images/hero-image.png" alt="Hero image" class="cf-home-hero-image" />
        </div>
    </div>
</section>

<section class="cf-highlight-bar">
    <div class="cf-container cf-highlight-bar-inner">
        <img src="~/images/brand-1.png" alt="Brand 1" height="24" />
        <img src="~/images/brand-2.png" alt="Brand 2" height="24" />
        <img src="~/images/brand-3.png" alt="Brand 3" height="24" />
        <img src="~/images/brand-4.png" alt="Brand 4" height="24" />
        <img src="~/images/brand-5.png" alt="Brand 5" height="24" />
    </div>
</section>

<section class="cf-section">
    <div class="cf-container cf-two-col">
        <div class="cf-image-stack">
            <img src="~/images/about-us-image.png" alt="About us" class="cf-stack-img cf-stack-img-main" />
            <img src="~/images/quote-image.png" alt="Quote image" class="cf-stack-img cf-stack-img-small" />
        </div>

        <div>
            <span class="cf-section-label">About Us</span>

            <h2 class="cf-section-title">
                Elevating Fitness Journey
                with Expert Guidance
            </h2>

            <p class="cf-section-text">
                Our supportive team and modern training environment help members build
                strength, improve health, and stay motivated every day.
            </p>

            <p class="cf-section-text">
                We focus on practical routines, smart coaching and long-term fitness success.
            </p>
        </div>
    </div>
</section>

<section class="cf-section">
    <div class="cf-container">
        <div class="cf-section-heading-center">
            <span class="cf-section-label">Our Program</span>
            <h2 class="cf-section-title-center">
                Professional training program for stronger health
            </h2>
        </div>

        <div class="cf-card-grid cf-card-grid-3">
            <div class="cf-photo-card">
                <img src="~/images/program-image-1.png" alt="Program 1" />
            </div>
            <div class="cf-photo-card">
                <img src="~/images/program-image-2.png" alt="Program 2" />
            </div>
            <div class="cf-photo-card">
                <img src="~/images/program-image-3.png" alt="Program 3" />
            </div>
        </div>
    </div>
</section>

<section class="cf-section">
    <div class="cf-container">
        <div class="cf-section-heading-center">
            <span class="cf-section-label">Shop</span>
            <h2 class="cf-section-title-center">
                High quality fitness products
            </h2>
        </div>

        <div class="cf-product-row">
            <img src="~/images/store-image-1.png" alt="Store 1" class="cf-product-img" />
            <img src="~/images/store-image-2.png" alt="Store 2" class="cf-product-img" />
            <img src="~/images/store-image-3.png" alt="Store 3" class="cf-product-img" />
            <img src="~/images/store-image-4.png" alt="Store 4" class="cf-product-img" />
        </div>
    </div>
</section>

