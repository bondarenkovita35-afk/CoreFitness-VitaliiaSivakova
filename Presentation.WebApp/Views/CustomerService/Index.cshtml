@{
    ViewData["Title"] = "Customer Service";
}

<section class="cf-page-section">
    <div class="cf-container">
        <div class="cf-section-heading">
            <h1>Customer Service</h1>
        </div>

        <div class="cf-two-col cf-contact-top">
            <div class="cf-contact-image-card">
                <img src="~/images/contact-us-image.png" alt="Contact us image" class="cf-full-image" />

                <div class="cf-contact-mini-bar">
                    <div><strong>Phone Number</strong><br />(+46) 08 123 123</div>
                    <div><strong>Email Address</strong><br />info@corefitness.com</div>
                </div>
            </div>

            <div class="cf-contact-form-wrap">
                <h2>Contact Us Today</h2>
                <p>Reach out to us if you have questions about memberships, training, classes or your account.</p>

                <form class="cf-form">
                    <div class="cf-form-grid">
                        <div>
                            <label>First Name</label>
                            <input class="cf-input" type="text" placeholder="Enter First Name" />
                        </div>
                        <div>
                            <label>Last Name</label>
                            <input class="cf-input" type="text" placeholder="Enter Last Name" />
                        </div>
                        <div>
                            <label>Email Address</label>
                            <input class="cf-input" type="email" placeholder="Enter Email Address" />
                        </div>
                        <div>
                            <label>Phone Number</label>
                            <input class="cf-input" type="text" placeholder="Enter Phone Number" />
                        </div>
                    </div>

                    <div>
                        <label>Message</label>
                        <textarea class="cf-input cf-textarea" placeholder="Write your message"></textarea>
                    </div>

                    <button type="submit" class="cf-btn-submit">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</section>

<section class="cf-section">
    <div class="cf-container cf-two-col">
        <div>
            <img src="~/images/faq-image.png" alt="FAQ image" class="cf-large-photo" />
        </div>

        <div>
            <span class="cf-section-label">Common Questions</span>

            <h2 class="cf-section-title">
                Common questions about gym and training
            </h2>

            <div class="cf-faq-list">
                <div class="cf-faq-item cf-faq-item-open">
                    <h4>Do I need prior gym experience to join CoreFitness?</h4>
                    <p>No. Beginners are welcome and supported with guidance and structure.</p>
                </div>
                <div class="cf-faq-item"><h4>What facilities are included with the membership?</h4></div>
                <div class="cf-faq-item"><h4>Can I try the gym before taking a membership?</h4></div>
                <div class="cf-faq-item"><h4>Are there group workout programs available?</h4></div>
                <div class="cf-faq-item"><h4>Is nutrition guidance included in the plans?</h4></div>
            </div>
        </div>
    </div>
</section>

