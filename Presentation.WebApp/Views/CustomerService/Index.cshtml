@{
    ViewData["Title"] = "Customer Service";
}

<section class="cf-section">
    <div class="cf-container">
        <div class="cf-section-heading-center">
            <h1 class="cf-page-title-center">Customer Service</h1>
        </div>

        <div class="cf-two-col cf-contact-top">
            <div class="cf-contact-image-card">
                <img src="~/images/customer-woman.jpg" alt="Customer support" class="cf-contact-main-image" />
                <div class="cf-contact-badges">
                    <div class="cf-contact-badge">
                        <strong>Phone Number</strong>
                        <span>+(46) 8 410 821 00</span>
                    </div>
                    <div class="cf-contact-badge">
                        <strong>Email Address</strong>
                        <span>info@corefitness.com</span>
                    </div>
                </div>
            </div>

            <div class="cf-contact-form-wrap">
                <h2 class="cf-section-title">Contact Us Today</h2>
                <p class="cf-section-text">
                    Reach out to us with questions about memberships, training and support.
                </p>

                <form class="cf-form">
                    <div class="cf-form-row">
                        <div class="cf-form-group">
                            <label>First Name</label>
                            <input class="cf-input" type="text" placeholder="Enter First Name" />
                        </div>
                        <div class="cf-form-group">
                            <label>Last Name</label>
                            <input class="cf-input" type="text" placeholder="Enter Last Name" />
                        </div>
                    </div>

                    <div class="cf-form-row">
                        <div class="cf-form-group">
                            <label>Email Address</label>
                            <input class="cf-input" type="email" placeholder="Enter Email Address" />
                        </div>
                        <div class="cf-form-group">
                            <label>Phone Number</label>
                            <input class="cf-input" type="text" placeholder="Enter Phone Number" />
                        </div>
                    </div>

                    <div class="cf-form-group">
                        <label>Message</label>
                        <textarea class="cf-input cf-textarea" placeholder="Write here"></textarea>
                    </div>

                    <button type="submit" class="cf-btn-primary cf-btn-no-border">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</section>

<section class="cf-section">
    <div class="cf-container cf-two-col">
        <div>
            <img src="~/images/faq-man.jpg" alt="FAQ training" class="cf-large-photo" />
        </div>

        <div class="cf-section-content">
            <span class="cf-section-label">Questions</span>
            <h2 class="cf-section-title">Common questions about gym and training</h2>

            <div class="cf-faq-list">
                <div class="cf-faq-item cf-faq-item-open">
                    <h4>Q1. Do I need prior gym experience to join CoreFitness?</h4>
                    <p>No. CoreFitness is designed for all fitness levels and goals.</p>
                </div>
                <div class="cf-faq-item"><h4>Q2. What facilities are included with the membership?</h4></div>
                <div class="cf-faq-item"><h4>Q3. Can I try the gym before taking a membership?</h4></div>
                <div class="cf-faq-item"><h4>Q4. Are there group workout programs available?</h4></div>
                <div class="cf-faq-item"><h4>Q5. Is nutrition guidance included in the plans?</h4></div>
            </div>
        </div>
    </div>
</section>