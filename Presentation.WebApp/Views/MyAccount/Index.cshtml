@model Presentation.WebApp.Models.MyAccountViewModel

@{
    ViewData["Title"] = "My Account";
}

<section class="cf-page-section">
    <div class="cf-container">
        <div class="cf-section-heading">
            <h1>My Account</h1>
        </div>

        @* Visar meddelande efter medlemskap eller avbokning *@
        @if (TempData["MembershipMessage"] != null)
        {
            <div class="cf-booking-message">
                @TempData["MembershipMessage"]
            </div>
        }

        @if (TempData["BookingMessage"] != null)
        {
            <div class="cf-booking-message">
                @TempData["BookingMessage"]
            </div>
        }

        <div class="cf-account-layout">
            <aside class="cf-account-sidebar">
                <img src="~/images/profile-image-avatar.png" alt="Profile avatar" class="cf-account-avatar" />

                <div class="cf-account-menu">
                    <div class="cf-account-menu-title">Menu Options</div>
                    <a class="cf-account-link active">About Me</a>
                    <a class="cf-account-link">My Membership</a>
                    <a class="cf-account-link">My Bookings</a>
                </div>
            </aside>

            <div class="cf-account-content">
                <div class="cf-account-form-block">
                    <h2>About Me</h2>

                    @* Visar användarens information *@
                    <div class="cf-account-info">
                        <p><strong>First Name:</strong> @Model.FirstName</p>
                        <p><strong>Last Name:</strong> @Model.LastName</p>
                        <p><strong>Email:</strong> @Model.Email</p>
                        <p><strong>Phone Number:</strong> @(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "Not added" : Model.PhoneNumber)</p>
                    </div>
                </div>

                <div class="cf-account-stats">
                    <h2>My Membership</h2>

                    @* Visar medlemskap om det finns *@
                    @if (Model.Membership == null)
                    {
                        <p>You do not have a membership yet.</p>
                    }
                    else
                    {
                        <div class="cf-booking-item">
                            <h3>@Model.Membership.Name</h3>
                            <p><strong>Price:</strong> @Model.Membership.Price SEK</p>
                            <p><strong>Status:</strong> @(Model.Membership.IsActive ? "Active" : "Inactive")</p>
                        </div>
                    }
                </div>

                <div class="cf-account-stats">
                    <h2>My Booked Classes</h2>

                    @* Om användaren inte har några bokningar *@
                    @if (!Model.BookedTrainings.Any())
                    {
                        <p>You have no booked classes yet.</p>
                    }
                    else
                    {
                        <div class="cf-booking-list">
                            @foreach (var booking in Model.BookedTrainings)
                            {
                                <div class="cf-booking-item">
                                    <h3>@booking.Title</h3>
                                    <p><strong>Category:</strong> @booking.Category</p>
                                    <p><strong>Instructor:</strong> @booking.InstructorName</p>
                                    <p><strong>Time:</strong> @booking.StartTime.ToString("yyyy-MM-dd HH:mm")</p>

                                    @* Formulär för att avboka passet *@
                                    <form asp-controller="Booking" asp-action="Cancel" method="post">
                                        <input type="hidden" name="bookingId" value="@booking.BookingId" />
                                        <button type="submit" class="cf-btn-cancel">Cancel Booking</button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>