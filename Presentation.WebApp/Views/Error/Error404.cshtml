@{
    ViewData["Title"] = "404";
}

<section class="cf-section">
    <div class="cf-container cf-error-wrap">
        <img src="~/images/not-found.png" alt="404" class="cf-error-image" />
        <h1 class="cf-error-title">Oops! page not found</h1>
        <p class="cf-error-text">The page you are looking for does not exist.</p>
        <a asp-controller="Home" asp-action="Index" class="cf-btn-primary">Back to Homepage</a>
    </div>
</section>