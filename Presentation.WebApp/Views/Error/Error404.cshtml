@{
    ViewData["Title"] = "404 - Not Found";
}

<section class="cf-page-section">
    <div class="cf-container">
        <div class="cf-notfound">
            <div class="cf-notfound-numbers">
                <span>4</span>
                <img src="~/images/404-error-image.png" alt="404 error image" />
                <span>4</span>
            </div>

            <h1>Oops! page not found</h1>
            <p>The page you are looking for does not exist.</p>

            <a asp-controller="Home" asp-action="Index" class="cf-btn-primary">Back to Homepage</a>
        </div>
    </div>
</section>

