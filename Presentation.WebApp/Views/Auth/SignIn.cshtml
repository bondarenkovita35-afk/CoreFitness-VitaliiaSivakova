@{
    ViewData["Title"] = "Sign In";
}

<div class="cf-auth">
    <div class="cf-auth-card">
        <h2>Welcome Back</h2>
        <p class="cf-muted">Sign in to your account</p>

        <form>
            <input type="email" placeholder="Email" class="cf-input" />
            <input type="password" placeholder="Password" class="cf-input" />

            <button class="cf-btn-primary">Sign In</button>
        </form>

        <p class="cf-auth-link">
            Don’t have an account?
            <a href="/Auth/SignUp">Sign Up</a>
        </p>
    </div>
</div>