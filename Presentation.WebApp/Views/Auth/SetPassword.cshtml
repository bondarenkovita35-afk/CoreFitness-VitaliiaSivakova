@{
    ViewData["Title"] = "Set Password";
}

<div class="cf-auth">
    <div class="cf-auth-card">
        <h2>Set Your Password</h2>
        <p class="cf-muted">Create a secure password</p>

        <form class="cf-form">
            @* Nytt lösenord *@
            <div>
                <input type="password" class="cf-input" placeholder="New Password" />
            </div>

            @* Bekräfta nytt lösenord *@
            <div>
                <input type="password" class="cf-input" placeholder="Confirm Password" />
            </div>

            <button type="submit" class="cf-btn-primary">Save Password</button>
        </form>
    </div>
</div>