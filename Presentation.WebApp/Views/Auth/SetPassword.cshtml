@{
    ViewData["Title"] = "Set Password";
}

<div class="cf-auth">
    <div class="cf-auth-card">
        <h2>Set Your Password</h2>
        <p class="cf-muted">Create a secure password</p>

        <form>
            <input type="password" placeholder="New Password" class="cf-input" />
            <input type="password" placeholder="Confirm Password" class="cf-input" />

            <button class="cf-btn-primary">Save Password</button>
        </form>
    </div>
</div>