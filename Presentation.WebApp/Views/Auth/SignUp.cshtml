@{
    ViewData["Title"] = "Sign Up";
}

<div class="cf-auth">
    <div class="cf-auth-card">
        <h2>Create Account</h2>
        <p class="cf-muted">Join CoreFitness today</p>

        <form>
            <input type="text" placeholder="Full Name" class="cf-input" />
            <input type="email" placeholder="Email" class="cf-input" />
            <input type="password" placeholder="Password" class="cf-input" />

            <button class="cf-btn-primary">Sign Up</button>
        </form>

        <p class="cf-auth-link">
            Already have an account?
            <a href="/Auth/SignIn">Sign In</a>
        </p>
    </div>
</div>